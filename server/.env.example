# --- 29projects-api environment ---

# Postgres connection string.
# On Railway, add a Postgres database to the project and reference it as:
#   DATABASE_URL = ${{ Postgres.DATABASE_URL }}
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Token required to read submissions via GET /api/briefs.
# Set to a long random string (e.g. `openssl rand -hex 32`).
ADMIN_TOKEN="change-me-to-a-long-random-string"

# Comma-separated CORS allow-list. If unset, defaults to the production domains.
ALLOWED_ORIGINS="https://29projectslab.com,https://www.29projectslab.com,https://29projects-ui-sand.vercel.app"

# Port. Railway provides PORT automatically; this is only for local runs.
PORT=3000
